# ============================================
# SHAX PUBG MARKETPLACE — Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_PROJECT_ID=your_project_id

# Site
NEXT_PUBLIC_SITE_URL=https://shax.uz
NEXT_PUBLIC_SITE_NAME=Shax PUBG Marketplace
NEXT_PUBLIC_DEFAULT_LOCALE=uz

# Payment (Payme / Click / Stripe)
NEXT_PUBLIC_PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_SECRET_KEY=your_payme_secret
NEXT_PUBLIC_CLICK_SERVICE_ID=your_click_service_id
CLICK_SECRET_KEY=your_click_secret

# CDN
NEXT_PUBLIC_CDN_URL=https://cdn.shax.uz

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_YANDEX_METRICA_ID=XXXXXXXX

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@shax.uz

# Admin
ADMIN_SECRET=strong_random_secret_here
